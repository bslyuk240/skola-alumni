# Skola Alumni — Environment Variables
# Copy this file to .env.local and fill in real values.
# See src/config/env.ts for the runtime validator (Zod) that enforces these at startup.

# --- Database: Neon Serverless Postgres ---
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/skola_alumni?sslmode=require"

# --- Redis: Upstash ---
REDIS_URL="redis://default:token@upstash.io:6379"

# --- Auth: Clerk ---
# CLERK_PUBLISHABLE_KEY must be set to the same value as NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY —
# clerkMiddleware's redirect/handshake logic reads the server-only (no NEXT_PUBLIC_ prefix) var directly.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxx"
CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_REPLACE_WITH_YOUR_CLERK_SECRET_KEY"
CLERK_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxx"
# Point Clerk's own redirect/handshake logic (used by auth.protect()) at our branded pages
# instead of its hosted Account Portal.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# --- Payments: Paystack (SaaS billing) ---
# Secret Key (starts with sk_test_) — Dashboard > Settings > API Keys & Webhooks.
# Used server-side only: API calls + webhook signature verification (Paystack has no separate
# webhook secret like Stripe — it signs with this same key).
PAYSTACK_SECRET_KEY="sk_test_REPLACE_WITH_YOUR_PAYSTACK_SECRET_KEY"
# Public Key (starts with pk_test_) — same dashboard page. Safe to expose client-side;
# used to open Paystack's checkout popup in the browser.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxx"

# --- Media: Cloudinary (post images/VOD uploads) ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_SECRET=""

# --- Live video: Cloudflare Stream (TikTok-style live; paid-plan feature) ---
# Account ID — Dashboard home sidebar / Workers overview → Account ID
CLOUDFLARE_ACCOUNT_ID=""
# API token — My Profile → API Tokens → Create Custom Token → Account → Stream → Edit
CLOUDFLARE_STREAM_API_TOKEN=""
# Customer code from URLs like https://customer-<CODE>.cloudflarestream.com/...
# Stream → Live inputs → open any input / embed URL and copy the CODE segment
CLOUDFLARE_STREAM_CUSTOMER_CODE=""

# --- Email: Resend ---
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"

# --- App ---
# Must include protocol (https://). Used as fallback when Origin header is missing.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Monitoring / Analytics (optional at MVP stage) ---
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
SENTRY_DSN=""
AXIOM_TOKEN=""
AXIOM_DATASET=""

# --- Push Notifications: Firebase Cloud Messaging (optional at MVP stage) ---
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
# Web Push "VAPID key" — Firebase Console > Project Settings > Cloud Messaging tab > Web Push
# certificates > Generate key pair. Needed for the browser to request a push subscription.
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""
# Service account JSON (server-side, for actually SENDING pushes) — Project Settings > Service
# Accounts > Generate new private key. Paste the whole JSON as a single-line string.
FIREBASE_SERVICE_ACCOUNT_JSON=""
